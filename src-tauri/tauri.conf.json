{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QuotaPeek",
  "version": "0.1.0",
  "identifier": "com.mac.quotapeek",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "claude",
        "title": "Claude Usage",
        "url": "index.html?provider=claude",
        "width": 344,
        "height": 432,
        "x": 60,
        "y": 60,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "visible": false,
        "center": false
      },
      {
        "label": "codex",
        "title": "Codex Usage",
        "url": "index.html?provider=codex",
        "width": 344,
        "height": 432,
        "x": 420,
        "y": 60,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "visible": false,
        "center": false
      },
      {
        "label": "settings",
        "title": "Settings",
        "url": "settings.html",
        "width": 360,
        "height": 330,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
